  FAMILY_MESSAGE
  WELLBEING_REMINDER
}

// ─────────────────────────────────────────────
// eMAR — MEDICATION MANAGEMENT
// ─────────────────────────────────────────────

model Medication {
  id              String   @id @default(cuid())
  residentId      String
  organisationId  String

  name            String
  genericName     String?
  dose            String
  unit            String
  route           MedicationRoute
  frequency       String          // e.g. "Once daily", "Twice daily"
  scheduledTimes  String[]        // e.g. ["08:00","20:00"]
  startDate       DateTime
  endDate         DateTime?
  prescribedBy    String?

  isControlled    Boolean  @default(false)
  isPRN           Boolean  @default(false)   // As Required
  prnIndication   String?
  isActive        Boolean  @default(true)

  currentStock    Int      @default(0)
  reorderLevel    Int      @default(7)        // days supply alert

  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  resident        Resident               @relation(fields: [residentId], references: [id])
  administrations MedicationAdministration[]
  cdEntries       ControlledDrugRegister[]
  stockAlerts     StockAlert[]

  @@index([residentId])
  @@index([organisationId])
}

model MedicationAdministration {
  id              String                  @id @default(cuid())
  medicationId    String
  residentId      String
  organisationId  String
  administeredById String
  witnessId       String?                 // For controlled drugs

  status          AdministrationStatus
  scheduledTime   DateTime
  administeredAt  DateTime?
  outcome         String?                 // reason for refusal/omission
  prnFollowUpDue  DateTime?               // for PRN meds
  prnFollowUpNote String?

  signedAt        DateTime?
  witnessSigned   Boolean  @default(false)
  witnessSignedAt DateTime?

  createdAt       DateTime @default(now())

  medication      Medication @relation(fields: [medicationId], references: [id])

  @@index([medicationId])
  @@index([residentId])
  @@index([organisationId, scheduledTime])
}

model ControlledDrugRegister {
  id              String   @id @default(cuid())
  medicationId    String
  organisationId  String
  administeredById String
  witnessId       String

  transactionType CDTransactionType
  quantity        Int
  balanceBefore   Int
  balanceAfter    Int
  notes           String?
  createdAt       DateTime @default(now())

  medication      Medication @relation(fields: [medicationId], references: [id])

  @@index([medicationId])
  @@index([organisationId, createdAt])
}

model MedicationAudit {
  id              String   @id @default(cuid())
  residentId      String
  organisationId  String
  auditMonth      DateTime // First day of month
  reportData      Json     // Stats: administered, refused, omitted, etc.
  generatedAt     DateTime @default(now())
  exportedAt      DateTime?

  @@index([residentId])
  @@index([organisationId, auditMonth])
}

// ─────────────────────────────────────────────
// GP COMMUNICATION MODULE
// ─────────────────────────────────────────────

model GPCommunication {
  id              String   @id @default(cuid())
  residentId      String
  organisationId  String
  authorId        String

  type            GPCommunicationType
  status          GPCommunicationStatus @default(DRAFT)

  subject         String
  aiDraftContent  String?
  finalContent    String?

  approvedById    String?
  approvedAt      DateTime?

  sentAt          DateTime?
  sentMethod      String?   // email, fax, hand-delivered
  recipientEmail  String?

  followUpDate    DateTime?
  followUpReceived Boolean  @default(false)
  gpResponseNotes  String?

  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  resident        Resident @relation(fields: [residentId], references: [id])

  @@index([residentId])
  @@index([organisationId])
  @@index([organisationId, status])
}

// ─────────────────────────────────────────────
// PHARMACY INTEGRATION
// ─────────────────────────────────────────────

model Pharmacy {
  id              String   @id @default(cuid())
  organisationId  String
  name            String
  contactName     String?
  phone           String?
  email           String?
  address         String?
  accountNumber   String?
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organisation    Organisation      @relation(fields: [organisationId], references: [id])
  orders          PrescriptionOrder[]

  @@index([organisationId])
}

model PrescriptionOrder {
  id              String   @id @default(cuid())
  organisationId  String
  pharmacyId      String
  createdById     String

  orderMonth      DateTime // First day of month
  status          OrderStatus @default(DRAFT)
  lineItems       Json     // Array of {medicationId, name, dose, qty, notes}

  submittedAt     DateTime?
  confirmedAt     DateTime?
  dispensedAt     DateTime?
  deliveredAt     DateTime?

  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organisation    Organisation @relation(fields: [organisationId], references: [id])
  pharmacy        Pharmacy     @relation(fields: [pharmacyId], references: [id])

  @@index([organisationId])
  @@index([pharmacyId])
}

model StockAlert {
  id              String   @id @default(cuid())
  medicationId    String
  organisationId  String
  alertType       StockAlertType
  currentStock    Int
  reorderLevel    Int
  isResolved      Boolean  @default(false)
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  medication      Medication @relation(fields: [medicationId], references: [id])

  @@index([organisationId, isResolved])
}

// ─────────────────────────────────────────────
// AI RISK ANALYTICS
// ─────────────────────────────────────────────

model RiskProfile {
  id                     String   @id @default(cuid())
  residentId             String   @unique
  organisationId         String

  resident               Resident @relation(fields: [residentId], references: [id])

  fallScore              Int      @default(0)   // 0-100
  pressureUlcerScore     Int      @default(0)
  medicationScore        Int      @default(0)
  safeguardingScore      Int      @default(0)
  combinedScore          Int      @default(0)   // weighted average

  fallRiskLevel          RiskLevel @default(LOW)
  pressureUlcerRiskLevel RiskLevel @default(LOW)
  medicationRiskLevel    RiskLevel @default(LOW)
  safeguardingRiskLevel  RiskLevel @default(LOW)
  overallRiskLevel       RiskLevel @default(LOW)

  aiRecommendations      String?  // GPT-4o-mini generated
  lastCalculatedAt       DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  factors                RiskFactor[]

  @@index([organisationId])
  @@index([organisationId, overallRiskLevel])
}

model RiskFactor {
  id              String   @id @default(cuid())
  riskProfileId   String
  domain          RiskDomain
  description     String
  weight          Int      // contribution weight 1-10
  isResolved      Boolean  @default(false)
  resolvedAt      DateTime?
  resolvedNotes   String?
  createdAt       DateTime @default(now())

  riskProfile     RiskProfile @relation(fields: [riskProfileId], references: [id])

  @@index([riskProfileId])
}

model RiskAcknowledgement {
  id              String   @id @default(cuid())
  residentId      String
  organisationId  String
  acknowledgedById String
  domain          RiskDomain
  notes           String
  createdAt       DateTime @default(now())

  @@index([residentId])
  @@index([organisationId])
}

// ─────────────────────────────────────────────
// NEW ENUMS (Phase 2)
// ─────────────────────────────────────────────

enum MedicationRoute {
  ORAL
  SUBLINGUAL
  TOPICAL
  TRANSDERMAL
  INHALED
  SUBCUTANEOUS
  INTRAMUSCULAR
  INTRAVENOUS
  RECTAL
  EYE_DROP
  EAR_DROP
  NASAL
  OTHER
}

enum AdministrationStatus {
  GIVEN
  REFUSED
  OMITTED
  NOT_AVAILABLE
  PENDING
}

enum CDTransactionType {
  ADMINISTERED
  RECEIVED
  RETURNED
  DESTROYED
  DISCREPANCY
}

enum GPCommunicationType {
  PRESCRIPTION_REQUEST
  CLINICAL_CONCERN
  MEDICATION_REVIEW
  URGENT_REFERRAL
  ROUTINE_UPDATE
  OTHER
}

enum GPCommunicationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  FOLLOW_UP_OVERDUE
  CLOSED
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  DISPENSED
  DELIVERED
  CANCELLED
}

enum StockAlertType {
  LOW_STOCK
  OUT_OF_STOCK
}

enum RiskDomain {
  FALLS
  PRESSURE_ULCER
  MEDICATION
  SAFEGUARDING
}

// ─────────────────────────────────────────────
// FAMILY PORTAL (Phase 3)
// ─────────────────────────────────────────────

model FamilyUser {
  id               String    @id @default(cuid())
  residentId       String
  organisationId   String
  email            String    @unique
  passwordHash     String?
  firstName        String
  lastName         String
  relationship     String    // e.g. "Daughter", "Son", "Power of Attorney"
  phone            String?
  isActive         Boolean   @default(true)
  inviteToken      String?   @unique
  inviteExpiresAt  DateTime?
  inviteAcceptedAt DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  resident         Resident        @relation(fields: [residentId], references: [id])
  sentMessages     FamilyMessage[] @relation("FamilyMessageFromFamily")

  @@index([residentId])
  @@index([organisationId])
}

model FamilyMessage {
  id               String    @id @default(cuid())
  residentId       String
  organisationId   String
  fromFamilyUserId String?
  fromStaffId      String?
  subject          String?
  body             String
  isRead           Boolean   @default(false)
  readAt           DateTime?
  createdAt        DateTime  @default(now())

  resident         Resident    @relation(fields: [residentId], references: [id])
  fromFamilyUser   FamilyUser? @relation("FamilyMessageFromFamily", fields: [fromFamilyUserId], references: [id])
  fromStaff        User?       @relation("FamilyMessageFromStaff", fields: [fromStaffId], references: [id])

  @@index([residentId])
  @@index([organisationId])
}

model WellbeingUpdate {
  id            String         @id @default(cuid())
  residentId    String
  organisationId String
  createdById   String
  mood          WellbeingMood
  appetite      WellbeingLevel
  sleep         WellbeingLevel
  activityLevel WellbeingLevel
  note          String?
  photoUrls     String[]
  isPublished   Boolean        @default(true)
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())

  resident      Resident @relation(fields: [residentId], references: [id])
  createdBy     User     @relation("WellbeingUpdateCreatedBy", fields: [createdById], references: [id])

  @@index([residentId])
  @@index([organisationId, createdAt])
}

enum WellbeingMood {
  VERY_HAPPY
  HAPPY
  NEUTRAL
  SAD
  DISTRESSED
}

enum WellbeingLevel {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

// ─────────────────────────────────────────────
// AI PATTERN RECOGNITION
// ─────────────────────────────────────────────

model PatternAlert {
  id               String               @id @default(cuid())
  residentId       String
  organisationId   String
  severity         PatternAlertSeverity
  category         String
  title            String
  description      String
  evidence         Json
  recommendation   String?
  status           PatternAlertStatus   @default(OPEN)
  dismissReason    String?
  actionNote       String?
  acknowledgedById String?
  acknowledgedAt   DateTime?
  periodFrom       DateTime
  periodTo         DateTime
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  resident         Resident @relation(fields: [residentId], references: [id])

  @@index([residentId])
  @@index([organisationId, status])
  @@index([organisationId, severity])
}

enum PatternAlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PatternAlertStatus {
  OPEN
  ACKNOWLEDGED
  ACTION_TAKEN
  DISMISSED
  CLOSED
}

// ─────────────────────────────────────────────
// INSPECTION READINESS
// ─────────────────────────────────────────────

model RegulatoryStandard {
  id             String         @id @default(cuid())
  regulatoryBody RegulatoryBody
  domain         String
  code           String
  title          String
  description    String
  dataMapping    Json
  weight         Int            @default(1)
  isActive       Boolean        @default(true)

  evidence       ComplianceEvidence[]

  @@unique([regulatoryBody, code])
  @@index([regulatoryBody, domain])
}

model ComplianceEvidence {
  id             String   @id @default(cuid())
  organisationId String
  standardId     String
  entityType     String
  entityId       String
  entityDate     DateTime
  residentId     String?
  residentName   String?
  summary        String
  isRecent       Boolean  @default(true)
  createdAt      DateTime @default(now())

  standard       RegulatoryStandard @relation(fields: [standardId], references: [id])

  @@index([organisationId, standardId])
  @@index([organisationId, entityType])
}

model MockInspectionReport {
  id               String            @id @default(cuid())
  organisationId   String
  regulatoryBody   RegulatoryBody
  overallRating    InspectionRating?
  domainRatings    Json
  reportContent    String
  strengthsSummary String?
  gapsSummary      String?
  actionPlan       Json?
  evidenceSnapshot Json
  generatedById    String?
  createdAt        DateTime          @default(now())

  @@index([organisationId])
  @@index([organisationId, createdAt])
}

enum InspectionRating {
  OUTSTANDING
  GOOD
  REQUIRES_IMPROVEMENT
  INADEQUATE
}

// ─────────────────────────────────────────────
// PHASE 4 — SCALE FEATURES
// ─────────────────────────────────────────────

// Step 22: Voice Input — CareNote already has content; we add audio fields
// via schema update to CareNote at migration time (audioUrl, transcriptionRaw, inputMethod)

// Step 23: Staff Management

model StaffProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  organisationId  String
  employeeRef     String?
  jobTitle        String?
  contractedHours Float    @default(0)
  startDate       DateTime?
  dbs             String?
  dbsExpiry       DateTime?
  phone           String?
  emergencyName   String?
  emergencyPhone  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])

  trainingRecords TrainingRecord[]
  supervisionLogs SupervisionLog[]
  rotaShifts      RotaShift[]

  @@index([organisationId])
}

model RotaShift {
  id              String       @id @default(cuid())
  organisationId  String
  staffProfileId  String
  date            DateTime     @db.Date
  shiftType       Shift
  startTime       String
  endTime         String
  role            String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  staffProfile    StaffProfile @relation(fields: [staffProfileId], references: [id])

  @@index([organisationId, date])
  @@index([staffProfileId])
}

model TrainingRecord {
  id              String              @id @default(cuid())
  staffProfileId  String
  organisationId  String
  trainingType    TrainingType
  completedAt     DateTime?
  expiresAt       DateTime?
  certificateUrl  String?
  notes           String?
  isCompleted     Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  staffProfile    StaffProfile        @relation(fields: [staffProfileId], references: [id])

  @@index([staffProfileId])
  @@index([organisationId, trainingType])
}

model SupervisionLog {
  id              String       @id @default(cuid())
  staffProfileId  String
  organisationId  String
  supervisorId    String
  supervisedAt    DateTime
  nextDueAt       DateTime?
  summary         String?
  actionPoints    String?
  createdAt       DateTime     @default(now())

  staffProfile    StaffProfile @relation(fields: [staffProfileId], references: [id])

  @@index([staffProfileId])
  @@index([organisationId])
}

// Step 24: Multi-Site Dashboard

model OrganisationGroup {
  id            String    @id @default(cuid())
  name          String
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships   GroupMembership[]
  groupUsers    GroupUser[]
}

model GroupMembership {
  id          String            @id @default(cuid())
  groupId     String
  orgId       String
  addedAt     DateTime          @default(now())

  group        OrganisationGroup @relation(fields: [groupId], references: [id])
  organisation Organisation      @relation(fields: [orgId], references: [id])

  @@unique([groupId, orgId])
  @@index([groupId])
  @@index([orgId])
}

model GroupUser {
  id        String            @id @default(cuid())
  groupId   String
  userId    String
  role      GroupUserRole     @default(VIEWER)
  createdAt DateTime          @default(now())

  group     OrganisationGroup @relation(fields: [groupId], references: [id])

  @@unique([groupId, userId])
  @@index([groupId])
}

// Step 25: GP & Healthcare Professional Portal

model ProfessionalUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  profession   String
  gmcNumber    String?
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accessGrants ProfessionalAccess[]
}

model ProfessionalAccess {
  id               String           @id @default(cuid())
  professionalId   String
  organisationId   String
  residentId       String
  grantedById      String
  grantedAt        DateTime         @default(now())
  expiresAt        DateTime
  isRevoked        Boolean          @default(false)
  revokedAt        DateTime?
  revokedById      String?
  accessType       ProfessionalAccessType @default(READ_ONLY)
  notes            String?

  professional     ProfessionalUser @relation(fields: [professionalId], references: [id])
  resident         Resident         @relation("ProfAccessResident", fields: [residentId], references: [id])
  grantedBy        User             @relation("ProfAccessGrantedBy", fields: [grantedById], references: [id])

  @@index([professionalId])
  @@index([organisationId])
  @@index([residentId])
  @@index([expiresAt])
}

