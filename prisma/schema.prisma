generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// MULTI-TENANCY
// ─────────────────────────────────────────────

model Organisation {
  id              String   @id @default(cuid())
  name            String
  type            String   @default("CARE_HOME")
  registrationNo  String?
  address         String?
  phone           String?
  email           String?
  regulatoryBody  RegulatoryBody @default(CQC)
  logoUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  residents       Resident[]
  careNotes       CareNote[]
  handoverReports HandoverReport[]
  incidents       Incident[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  pharmacies      Pharmacy[]
  prescriptionOrders PrescriptionOrder[]
  groupMemberships   GroupMembership[]
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  organisationId String
  email          String   @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole @default(CARE_STAFF)
  jobTitle       String?
  phone          String?
  avatarUrl      String?
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organisation        Organisation  @relation(fields: [organisationId], references: [id])
  careNotes           CareNote[]
  handoverReports     HandoverReport[]
  incidents           Incident[]
  incidentFollowUps   IncidentFollowUp[]
  bodyMapEntries      BodyMapEntry[]
  auditLogs           AuditLog[]
  careplanApprovals   CarePlan[]    @relation("CarePlanApprovedBy")
  assessmentDomains   AssessmentDomain[]
  familyMessages      FamilyMessage[] @relation("FamilyMessageFromStaff")
  wellbeingUpdates    WellbeingUpdate[] @relation("WellbeingUpdateCreatedBy")
  staffProfile        StaffProfile?
  professionalAccessesGranted ProfessionalAccess[] @relation("ProfAccessGrantedBy")

  @@index([organisationId])
}

// ─────────────────────────────────────────────
// RESIDENTS
// ─────────────────────────────────────────────

model Resident {
  id              String         @id @default(cuid())
  organisationId  String
  status          ResidentStatus @default(ENQUIRY)
  roomNumber      String?
  nhsNumber       String?

  // Personal
  firstName       String
  lastName        String
  preferredName   String?
  dateOfBirth     DateTime?
  gender          String?
  pronouns        String?
  nationality     String?
  religion        String?
  ethnicity       String?
  language        String?
  interpreterNeeded Boolean @default(false)

  // Admission
  admissionDate   DateTime?
  expectedStayType String?
  fundingType     String?
  referralSource  String?

  // Medical
  gpName          String?
  gpPractice      String?
  gpPhone         String?
  gpAddress       String?
  nhsLocalTeam    String?

  // Key flags
  dnacprInPlace   Boolean  @default(false)
  dnacprDate      DateTime?
  mentalCapacity  Boolean  @default(true)
  doLsAuthorised  Boolean  @default(false)

  photoUrl        String?
  notes           String?

  preAssessmentCompletedAt          DateTime?
  admissionAssessmentApprovedAt     DateTime?

  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organisation        Organisation         @relation(fields: [organisationId], references: [id])
  medicalHistory      ResidentMedical?
  contacts            ResidentContact[]
  assessments         ResidentAssessment[]
  carePlans           CarePlan[]
  careNotes           CareNote[]
  incidents           Incident[]
  bodyMapEntries      BodyMapEntry[]
  medications         Medication[]
  gpCommunications    GPCommunication[]
  riskProfile         RiskProfile?
  familyUsers         FamilyUser[]
  familyMessages      FamilyMessage[]
  wellbeingUpdates    WellbeingUpdate[]
  patternAlerts       PatternAlert[]
  professionalAccesses ProfessionalAccess[] @relation("ProfAccessResident")

  @@index([organisationId])
  @@index([organisationId, status])
}

model ResidentMedical {
  id               String   @id @default(cuid())
  residentId       String   @unique

  diagnoses        String[]
  allergies        String[]
  vaccinationAlerts String[]
  currentMedications String?

  mobilityLevel    MobilityLevel   @default(INDEPENDENT)
  mobilityAids     String[]

  continenceLevel  ContinenceLevel @default(CONTINENT)

  dietaryNeeds     String[]
  textureModified  Boolean  @default(false)
  textureLevel     String?
  fluidThickened   Boolean  @default(false)
  fluidThickness   String?

  skinIntegrityNotes String?
  smokingStatus    String?
  alcoholUse       String?
  additionalNeeds  String?

  updatedAt        DateTime @updatedAt

  resident         Resident @relation(fields: [residentId], references: [id])
}

model ResidentContact {
  id           String  @id @default(cuid())
  residentId   String
  relationship String
  firstName    String
  lastName     String
  phone        String?
  email        String?
  address      String?
  isNextOfKin  Boolean @default(false)
  isPoa        Boolean @default(false)
  isEmergency  Boolean @default(true)
  notes        String?
  createdAt    DateTime @default(now())

  resident     Resident @relation(fields: [residentId], references: [id])

  @@index([residentId])
}

// ─────────────────────────────────────────────
// ASSESSMENTS
// ─────────────────────────────────────────────

model ResidentAssessment {
  id             String           @id @default(cuid())
  residentId     String
  type           AssessmentType
  status         AssessmentStatus @default(IN_PROGRESS)
  reviewDate     DateTime?
  completedAt    DateTime?
  approvedAt     DateTime?
  approvedBy     String?
  version        Int              @default(1)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  resident  Resident           @relation(fields: [residentId], references: [id])
  domains   AssessmentDomain[]
  versions  AssessmentVersion[]

  @@index([residentId])
  @@index([residentId, type])
}

model AssessmentDomain {
  id            String  @id @default(cuid())
  assessmentId  String
  domainType    AssessmentDomainType
  content       Json
  score         Int?
  riskLevel     RiskLevel?
  isComplete    Boolean @default(false)
  completedById String?
  completedAt   DateTime?
  notes         String?
  updatedAt     DateTime @updatedAt

  assessment   ResidentAssessment @relation(fields: [assessmentId], references: [id])
  completedBy  User?              @relation(fields: [completedById], references: [id])

  @@unique([assessmentId, domainType])
  @@index([assessmentId])
}

model AssessmentVersion {
  id           String   @id @default(cuid())
  assessmentId String
  snapshot     Json
  createdAt    DateTime @default(now())
  createdBy    String?

  assessment ResidentAssessment @relation(fields: [assessmentId], references: [id])

  @@index([assessmentId])
}

// ─────────────────────────────────────────────
// CARE PLANS
// ─────────────────────────────────────────────

model CarePlan {
  id             String        @id @default(cuid())
  residentId     String
  organisationId String
  category       CarePlanCategory
  status         CarePlanStatus @default(DRAFT)

  needsAssessment   String?
  goals             Json?
  interventions     Json?
  outcomes          Json?

  aiPromptUsed   String?
  generatedByAi  Boolean  @default(false)

  reviewDate     DateTime?
  approvedAt     DateTime?
  approvedById   String?

  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  resident       Resident          @relation(fields: [residentId], references: [id])
  approvedBy     User?             @relation("CarePlanApprovedBy", fields: [approvedById], references: [id])
  versions       CarePlanVersion[]
  progressNotes  CarePlanProgressNote[]

  @@index([residentId])
  @@index([organisationId])
}

model CarePlanVersion {
  id          String   @id @default(cuid())
  carePlanId  String
  snapshot    Json
  createdAt   DateTime @default(now())
  createdBy   String?

  carePlan    CarePlan @relation(fields: [carePlanId], references: [id])

  @@index([carePlanId])
}

model CarePlanProgressNote {
  id         String   @id @default(cuid())
  carePlanId String
  note       String
  createdBy  String?
  createdAt  DateTime @default(now())

  carePlan   CarePlan @relation(fields: [carePlanId], references: [id])

  @@index([carePlanId])
}

// ─────────────────────────────────────────────
// CARE NOTES
// ─────────────────────────────────────────────

model CareNote {
  id             String          @id @default(cuid())
  residentId     String
  organisationId String
  authorId       String

  category       CareNoteCategory
  shift          Shift
  content        String
  aiSummary      String?
  audioUrl       String?
  transcriptionRaw String?
  inputMethod    CareNoteInputMethod @default(TYPED)

  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  resident       Resident     @relation(fields: [residentId], references: [id])
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  author         User         @relation(fields: [authorId], references: [id])

  @@index([residentId])
  @@index([organisationId])
  @@index([organisationId, createdAt])
}

// ─────────────────────────────────────────────
// HANDOVER REPORTS
// ─────────────────────────────────────────────

model HandoverReport {
  id             String   @id @default(cuid())
  organisationId String
  authorId       String
  shift          Shift
  shiftDate      DateTime

  content        Json
  manualAdditions String?
  rawNotesCount  Int      @default(0)

  createdAt      DateTime @default(now())

  organisation   Organisation @relation(fields: [organisationId], references: [id])
  author         User         @relation(fields: [authorId], references: [id])

  @@index([organisationId])
  @@index([organisationId, shiftDate])
}

// ─────────────────────────────────────────────
// INCIDENTS
// ─────────────────────────────────────────────

model Incident {
  id             String         @id @default(cuid())
  residentId     String
  organisationId String
  reportedById   String

  type           IncidentType
  severity       IncidentSeverity
  description    String
  location       String?
  occurredAt     DateTime
  witnesses      String?
  injuryDetails  String?
  firstAidGiven  Boolean @default(false)
  firstAidDetails String?
  familyNotified  Boolean @default(false)
  gpNotified      Boolean @default(false)

  status         IncidentStatus @default(OPEN)

  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  resident       Resident           @relation(fields: [residentId], references: [id])
  organisation   Organisation       @relation(fields: [organisationId], references: [id])
  reportedBy     User               @relation(fields: [reportedById], references: [id])
  followUps      IncidentFollowUp[]

  @@index([residentId])
  @@index([organisationId])
}

model IncidentFollowUp {
  id         String   @id @default(cuid())
  incidentId String
  note       String
  authorId   String
  createdAt  DateTime @default(now())

  incident   Incident @relation(fields: [incidentId], references: [id])
  author     User     @relation(fields: [authorId], references: [id])

  @@index([incidentId])
}

// ─────────────────────────────────────────────
// BODY MAP
// ─────────────────────────────────────────────

model BodyMapEntry {
  id             String          @id @default(cuid())
  residentId     String
  authorId       String

  bodyRegion     String
  description    String
  type           BodyMapEntryType
  severity       BodyMapSeverity
  photoUrls      String[]

  isResolved     Boolean  @default(false)
  resolvedAt     DateTime?
  resolvedNotes  String?

  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  resident       Resident @relation(fields: [residentId], references: [id])
  author         User     @relation(fields: [authorId], references: [id])

  @@index([residentId])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id             String   @id @default(cuid())
  organisationId String
  userId         String?

  type           NotificationType
  title          String
  body           String
  entityType     String?
  entityId       String?

  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  organisation   Organisation @relation(fields: [organisationId], references: [id])

  @@index([organisationId, isRead])
  @@index([userId])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  organisationId String
  userId         String

  action         String
  entityType     String
  entityId       String
  before         Json?
  after          Json?
  ipAddress      String?
  userAgent      String?

  createdAt      DateTime @default(now())

  organisation   Organisation @relation(fields: [organisationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([organisationId])
  @@index([organisationId, entityType])
  @@index([userId])
}

// ─────────────────────────────────────────────
